<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarWeeklyProgress"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_surface"
        android:title="📈 Mi Semana"
        android:titleTextColor="@color/color_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Week label -->
            <TextView
                android:id="@+id/textViewWeekRange"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:text="Semana actual" />

            <!-- XP card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/color_surface"
                android:padding="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XP GANADO"
                    android:textColor="@color/color_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/textViewWeeklyXPValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:text="+0 XP" />

                <TextView
                    android:id="@+id/textViewRankChange"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="2dp"
                    android:text="" />

                <ProgressBar
                    android:id="@+id/progressBarWeeklyXP"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="0" />

                <TextView
                    android:id="@+id/textViewWeeklyNextRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:text="" />

            </LinearLayout>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <!-- Streak -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/color_surface"
                    android:padding="14dp"
                    android:layout_marginEnd="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RACHA"
                        android:textColor="@color/color_primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/textViewStreakValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp"
                        android:text="—" />

                </LinearLayout>

                <!-- Posts -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/color_surface"
                    android:padding="14dp"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POSTS"
                        android:textColor="@color/color_primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/textViewWeeklyPostsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp"
                        android:text="0" />

                </LinearLayout>

                <!-- Likes -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@color/color_surface"
                    android:padding="14dp"
                    android:layout_marginStart="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIKES"
                        android:textColor="@color/color_primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/textViewWeeklyLikesValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp"
                        android:text="0" />

                </LinearLayout>

            </LinearLayout>

            <!-- Missions card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/color_surface"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MISIONES SEMANALES"
                    android:textColor="@color/color_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/textViewMissionsValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="10dp"
                    android:text="0 / 5 misiones completadas" />

                <LinearLayout
                    android:id="@+id/layoutMissionsProgress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
