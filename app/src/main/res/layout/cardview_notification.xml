<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="10dp"
    app:cardBackgroundColor="@color/color_surface"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imageViewNotifIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_bell"
            android:tint="@color/color_primary"
            android:padding="6dp"
            android:background="@color/color_surface_2" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/textViewNotifBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notificación"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:maxLines="2" />

            <TextView
                android:id="@+id/textViewNotifTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ahora"
                android:textColor="@color/color_text_secondary"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:layout_marginTop="3dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/textViewGroupCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+3"
                android:textSize="10sp"
                android:textColor="@color/color_primary"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <View
                android:id="@+id/viewUnreadDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@color/color_primary" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
