<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/color_surface"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textViewTournamentGame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Valorant"
                    android:textColor="@color/color_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textViewTournamentFormat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Eliminación directa"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/textViewTournamentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ABIERTO"
                android:textColor="@color/color_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@color/color_surface_2"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textViewTournamentPlayers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👥 1/8 jugadores"
                android:textColor="@color/color_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/textViewTournamentDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 15/05"
                android:textColor="@color/color_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

        <TextView
            android:id="@+id/textViewTournamentWinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Ganador: @gamer"
            android:textColor="@color/color_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
