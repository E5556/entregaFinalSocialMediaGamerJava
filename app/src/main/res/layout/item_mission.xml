<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="@color/color_surface"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/textViewMissionEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯"
                android:textSize="22sp"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textViewMissionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Misión"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textViewMissionDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Descripción de la misión"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <TextView
                android:id="@+id/textViewMissionReward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+30 XP"
                android:textColor="@color/color_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <ProgressBar
                android:id="@+id/progressBarMission"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:progressTint="@color/color_primary"
                android:progressBackgroundTint="@color/color_surface_2"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/textViewMissionProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/3"
                android:textColor="@color/color_text_secondary"
                android:textSize="11sp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <Button
            android:id="@+id/buttonMissionClaim"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:text="RECLAMAR RECOMPENSA"
            android:textSize="11sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:backgroundTint="@color/color_secondary"
            android:textColor="@color/colorWhite"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
