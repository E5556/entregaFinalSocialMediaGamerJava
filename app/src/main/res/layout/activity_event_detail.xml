<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/color_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/textViewEventDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/textViewEventDetailGame"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/color_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/textViewEventDetailPlatform"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/textViewEventDetailDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/color_surface_2"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/textViewEventDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.4" />

                <Button
                    android:id="@+id/btnEventDetailLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="VER ENLACE EXTERNO"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@color/color_primary"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/color_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ASISTENTES"
                        android:textColor="@color/color_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textViewEventDetailAttendeeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />

                </LinearLayout>

                <Button
                    android:id="@+id/btnEventDetailRSVP"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="APUNTARSE"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/color_primary" />

                <Button
                    android:id="@+id/btnEventGroupChat"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💬 CHAT GRUPAL"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/color_surface_2" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Predicciones -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:id="@+id/cardPrediction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="@color/color_surface"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚡ PREDICCIÓN"
                        android:textColor="@color/color_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/textViewPredictionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ABIERTA"
                        android:textColor="@color/color_primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                </LinearLayout>

                <TextView
                    android:id="@+id/textViewPredictionQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¿Quién ganará?"
                    android:textColor="@color/color_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/layoutPredictionOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/textViewPredictionResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Botón crear predicción (solo creador) -->
        <Button
            android:id="@+id/btnSetupPrediction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ AÑADIR PREDICCIÓN"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:backgroundTint="@color/color_secondary"
            android:textColor="@color/colorWhite"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
