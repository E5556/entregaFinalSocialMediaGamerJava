<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarSeason"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_surface"
        android:title="🏅 Temporadas"
        android:titleTextColor="@color/color_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Season header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/color_surface"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/textViewSeasonLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:text="🏅 Temporada" />

                <TextView
                    android:id="@+id/textViewSeasonSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:text="" />

                <Button
                    android:id="@+id/buttonCloseSeason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙️ CERRAR TEMPORADA"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:backgroundTint="@color/color_surface_2"
                    android:textColor="@color/color_text_primary"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Current season leaderboard -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RANKING DE LA TEMPORADA"
                android:textColor="@color/color_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layoutSeasonLeaderboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/color_surface"
                android:layout_marginBottom="16dp" />

            <!-- Hall of fame -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 SALÓN DE CAMPEONES"
                android:textColor="@color/color_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layoutHallOfFame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/color_surface" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
