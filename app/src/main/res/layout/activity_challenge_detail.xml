<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarChallengeDetail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/color_surface"
        android:title="⚔️ Desafío"
        android:titleTextColor="@color/color_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info card -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:id="@+id/textViewDetailPlayers"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@a  ⚔️  @b"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textViewDetailStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PENDIENTE"
                            android:textColor="@color/color_secondary"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:background="@color/color_surface_2"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/textViewDetailDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Descripción del desafío"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4" />

                    <TextView
                        android:id="@+id/textViewDetailWinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆 Ganador: @gamer"
                        android:textColor="@color/color_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Botones accept/reject (challenged, pending) -->
            <LinearLayout
                android:id="@+id/layoutAcceptReject"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <Button
                    android:id="@+id/buttonAccept"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✅ ACEPTAR"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:backgroundTint="@color/color_primary"
                    android:textColor="@color/color_background"
                    android:layout_marginEnd="6dp" />

                <Button
                    android:id="@+id/buttonReject"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="❌ RECHAZAR"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:backgroundTint="@color/color_surface_2"
                    android:textColor="@color/color_text_primary"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

            <!-- Evidencias -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardEvidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EVIDENCIAS"
                        android:textColor="@color/color_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/textViewEvidenceChallenger"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/textViewEvidenceChallenged"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/editTextEvidence"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Describe tu evidencia (resultado, etc.)"
                        android:textColor="@color/color_text_primary"
                        android:textColorHint="@color/color_text_secondary"
                        android:background="@color/color_surface_2"
                        android:padding="10dp"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/imageViewEvidencePreview"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:scaleType="centerCrop"
                        android:layout_marginTop="8dp"
                        android:background="@color/color_surface_2"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        android:id="@+id/layoutEvidenceButtons">

                        <Button
                            android:id="@+id/buttonPickEvidenceImage"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="📷 IMAGEN"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:backgroundTint="@color/color_surface_2"
                            android:textColor="@color/color_text_primary"
                            android:layout_marginEnd="6dp" />

                        <Button
                            android:id="@+id/buttonSubmitEvidence"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="2"
                            android:text="ENVIAR EVIDENCIA"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:backgroundTint="@color/color_secondary"
                            android:textColor="@color/colorWhite" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Votación -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:id="@+id/cardVoting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗳️ VOTACIÓN COMUNITARIA"
                        android:textColor="@color/color_primary"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/buttonVoteChallenger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Votar A\n0 votos"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:backgroundTint="@color/color_primary"
                            android:textColor="@color/color_background"
                            android:layout_marginEnd="6dp" />

                        <Button
                            android:id="@+id/buttonVoteChallenged"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Votar B\n0 votos"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:backgroundTint="@color/color_secondary"
                            android:textColor="@color/colorWhite"
                            android:layout_marginStart="6dp" />

                    </LinearLayout>

                    <!-- Finalizar (solo challengeador) -->
                    <Button
                        android:id="@+id/buttonFinish"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:text="🏆 CERRAR VOTACIÓN Y DECLARAR GANADOR"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:backgroundTint="@color/color_surface_2"
                        android:textColor="@color/color_text_primary"
                        android:layout_marginTop="10dp"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
